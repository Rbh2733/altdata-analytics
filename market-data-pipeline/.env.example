# Copy to .env (never committed) or export in your shell. All optional:
# the offline demo runs with none of these set.

# SEC EDGAR requires a descriptive User-Agent with a contact address for
# automated access, e.g. "your-project-name you@example.com".
SEC_USER_AGENT=

# Financial Modeling Prep API key; the fmp client joins live runs when set.
FMP_API_KEY=

# Polygon.io API key; the polygon client joins live runs when set.
POLYGON_API_KEY=
